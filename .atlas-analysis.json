  "keyFeatures": [
    "Plugin system with dependency injection and service locator",
    "Native game function hooking via Reloaded/MinHook backends",
    "ImGui-based overlay UI rendering with windowing system",
    "Game data access via Lumina (Excel sheets, raw files)",
    "In-game chat message interception and printing",
    "Slash command registration and dispatch",
    "Inter-Plugin Communication (IPC) via typed call gates",
    "Client state events (territory changes, login/logout, class changes)",
    "Texture loading and management from game files or disk",
    "Toast/notification system for in-game popups"
  ],
